# Database Configuration
DB_USERNAME=supermalle
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_256_bits_long_for_security
JWT_EXPIRATION=900000

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_api_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@supermalle.com
EMAIL_FROM_NAME=SuperMalle Restaurant

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5175,http://localhost:8080

# Frontend URL (used for email links, password reset, etc.)
FRONTEND_URL=http://localhost:5173

# Restaurant Information
RESTAURANT_NAME=SuperMalle Restaurant
RESTAURANT_PHONE=+1-555-123-4567
RESTAURANT_ADDRESS=123 Main St, City, State 12345

# Admin Credentials (used by DataInitializer to seed the default admin user)
ADMIN_EMAIL=admin@supermalle.com
ADMIN_PASSWORD=Admin@2026!

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=100
RATE_LIMIT_DEFAULT_DURATION=1
RATE_LIMIT_ADMIN_REQUESTS=1000
RATE_LIMIT_STAFF_REQUESTS=500
RATE_LIMIT_CUSTOMER_REQUESTS=100

# Encryption Configuration
# Generate a new key using: java -cp target/classes com.example.superMalle.security.AESUtil
ENCRYPTION_KEY=your_base64_encoded_256_bit_encryption_key_here

# RabbitMQ Configuration (set enabled=false if RabbitMQ is not running locally)
RABBITMQ_ENABLED=false
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Order Auto-Cancel Configuration
AUTO_CANCEL_MINUTES=30
AUTO_CANCEL_INTERVAL_MS=300000
